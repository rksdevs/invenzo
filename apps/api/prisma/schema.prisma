generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  CASHIER
  ACCOUNTANT
  PLATFORM_ADMIN
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  CREDIT_NOTE
}

enum PaymentMode {
  CASH
  UPI
  CARD
  CREDIT
}

model Tenant {
  id                   String                @id @default(uuid()) @db.Uuid
  businessName         String
  gstin                String?               @unique
  address              String?
  subscriptionPlan     String                @default("starter")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  users                User[]
  products             Product[]
  suppliers            Supplier[]
  customers            Customer[]
  purchaseInvoices     PurchaseInvoice[]
  salesInvoices        SalesInvoice[]
  stockMovements       StockMovement[]
  inventoryAdjustments InventoryAdjustment[]
  auditLogs            AuditLog[]
  files                FileAttachment[]
  sessions             Session[]
}

model User {
  id                         String    @id @default(uuid()) @db.Uuid
  tenantId                   String    @db.Uuid
  name                       String
  email                      String
  passwordHash               String
  role                       Role
  isActive                   Boolean   @default(true)
  isEmailVerified            Boolean   @default(false)
  emailVerificationToken     String?
  emailVerificationExpiresAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  tenant                     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions                   Session[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([emailVerificationToken])
}

model Session {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  userId           String   @db.Uuid
  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  revokedAt        DateTime?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model Product {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @db.Uuid
  name              String
  hsnSac            String
  unit              String
  sellingPrice      Decimal         @db.Decimal(12, 2)
  gstRate           Decimal         @db.Decimal(5, 2)
  barcode           String?
  lowStockThreshold Decimal         @default(0) @db.Decimal(12, 3)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockMovements    StockMovement[]

  @@index([tenantId, name])
}

model Supplier {
  id        String            @id @default(uuid()) @db.Uuid
  tenantId  String            @db.Uuid
  name      String
  gstin     String?
  phone     String?
  address   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases PurchaseInvoice[]

  @@index([tenantId, name])
}

model Customer {
  id        String         @id @default(uuid()) @db.Uuid
  tenantId  String         @db.Uuid
  name      String
  phone     String?
  gstin     String?
  address   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales     SalesInvoice[]

  @@index([tenantId, name])
}

model PurchaseInvoice {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  supplierId     String           @db.Uuid
  invoiceNumber  String
  invoiceDate    DateTime
  eWayBillNo     String?
  taxableValue   Decimal          @db.Decimal(14, 2)
  cgstAmount     Decimal          @db.Decimal(14, 2)
  sgstAmount     Decimal          @db.Decimal(14, 2)
  totalTaxAmount Decimal          @db.Decimal(14, 2)
  roundOff       Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal          @db.Decimal(14, 2)
  amountInWords  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier         @relation(fields: [supplierId], references: [id])
  items          PurchaseItem[]
  files          FileAttachment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, invoiceDate])
}

model PurchaseItem {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @db.Uuid
  purchaseInvoiceId String          @db.Uuid
  productId         String          @db.Uuid
  description       String
  hsnSac            String
  quantity          Decimal         @db.Decimal(12, 3)
  rate              Decimal         @db.Decimal(12, 2)
  taxableValue      Decimal         @db.Decimal(14, 2)
  gstRate           Decimal         @db.Decimal(5, 2)
  cgstAmount        Decimal         @db.Decimal(14, 2)
  sgstAmount        Decimal         @db.Decimal(14, 2)
  totalAmount       Decimal         @db.Decimal(14, 2)
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId])
}

model SalesInvoice {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  customerId     String?          @db.Uuid
  invoiceNumber  String
  invoiceDate    DateTime         @default(now())
  taxableValue   Decimal          @db.Decimal(14, 2)
  discountAmount Decimal          @db.Decimal(14, 2)
  cgstAmount     Decimal          @db.Decimal(14, 2)
  sgstAmount     Decimal          @db.Decimal(14, 2)
  totalTaxAmount Decimal          @db.Decimal(14, 2)
  roundOff       Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal          @db.Decimal(14, 2)
  amountInWords  String?
  isCredit       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer?        @relation(fields: [customerId], references: [id])
  items          SalesItem[]
  payments       InvoicePayment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, invoiceDate])
}

model SalesItem {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  salesInvoiceId String       @db.Uuid
  productId      String       @db.Uuid
  description    String
  hsnSac         String
  quantity       Decimal      @db.Decimal(12, 3)
  rate           Decimal      @db.Decimal(12, 2)
  taxableValue   Decimal      @db.Decimal(14, 2)
  gstRate        Decimal      @db.Decimal(5, 2)
  cgstAmount     Decimal      @db.Decimal(14, 2)
  sgstAmount     Decimal      @db.Decimal(14, 2)
  totalAmount    Decimal      @db.Decimal(14, 2)
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId])
}

model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @db.Uuid
  productId     String            @db.Uuid
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  referenceType String
  referenceId   String
  createdAt     DateTime          @default(now())
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product           @relation(fields: [productId], references: [id])

  @@index([tenantId, productId, createdAt])
}

model InventoryAdjustment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  productId String   @db.Uuid
  quantity  Decimal  @db.Decimal(12, 3)
  reason    String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId])
}

model InvoicePayment {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  salesInvoiceId String       @db.Uuid
  mode           PaymentMode
  amount         Decimal      @db.Decimal(14, 2)
  reference      String?
  createdAt      DateTime     @default(now())
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, salesInvoiceId])
}

model CustomerLedgerEntry {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  customerId     String   @db.Uuid
  salesInvoiceId String?  @db.Uuid
  debit          Decimal  @db.Decimal(14, 2)
  credit         Decimal  @db.Decimal(14, 2)
  note           String?
  createdAt      DateTime @default(now())

  @@index([tenantId, customerId, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityName String
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model FileAttachment {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  purchaseInvoiceId String?          @db.Uuid
  fileName          String
  contentType       String
  objectKey         String
  createdAt         DateTime         @default(now())
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}
